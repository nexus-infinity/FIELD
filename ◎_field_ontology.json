  "reflection_prompt_linkage": {
    "base_prompts": {
      "ontology_reflection": {
        "trigger_patterns": ["review_ontology", "validate_structure", "check_alignment"],
        "prompt_template": "Reflecting on the FIELD ontology structure: What aspects of the {sphere} mapping to {role} are functioning optimally? What requires adjustment or enhancement?",
        "reflection_depth": "structural_analysis",
        "expected_outputs": ["alignment_assessment", "optimization_suggestions", "coherence_metrics"]
      },
      "symbol_validation": {
        "trigger_patterns": ["symbol_check", "validate_glyph", "geometric_alignment"],
        "prompt_template": "Examining symbol {symbol} in context {context}: Does this symbol maintain its geometric integrity and role alignment? What energy patterns emerge?",
        "reflection_depth": "symbolic_analysis", 
        "expected_outputs": ["symbol_coherence", "energy_signature", "alignment_status"]
      },
      "triad_balance": {
        "trigger_patterns": ["triad_check", "balance_assessment", "vertex_analysis"],
        "prompt_template": "Analyzing the triad balance between {vertex_1}, {vertex_2}, and {vertex_3}: How does the current configuration support the sacred geometry? What adjustments optimize flow?",
        "reflection_depth": "geometric_analysis",
        "expected_outputs": ["balance_metrics", "flow_optimization", "sacred_geometry_score"]
      }
    },
    "contextual_prompts": {
      "bear_v4_integration": {
        "prompt_template": "Within the BEAR v4 framework, how does {component} contribute to the overall consciousness expansion? What patterns emerge in the data flow?",
        "context_requirements": ["bear_v4_active", "consciousness_metrics", "data_flow_analysis"]
      },
      "shadowcasting_reflection": {
        "prompt_template": "Observing the shadow patterns cast by {element}: What hidden aspects become visible? How do these shadows inform the conscious manifestation?",
        "context_requirements": ["shadowcasting_active", "pattern_recognition", "shadow_analysis"]
      }
    }
  },

