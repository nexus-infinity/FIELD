        return 1
    fi
    
    if [ ! -d "$repo_path/.git" ]; then
        echo "⚠️  Not a git repository: $repo_path"
        return 1
    fi
    
    echo "🔄 Syncing $repo_name..."
    cd "$repo_path"
    
    # Show status
    echo "   Status:"
    git status --porcelain | head -5
    
