#!/bin/bash
# Sacred Test Launcher Script
#
# Quick access to the Sacred Parallel Testing System.
# This script provides convenient shortcuts for common testing operations.
#
# Usage:
#     ./sacred-test status                          # Check system status
#     ./sacred-test test atlas unit                 # Run unit tests for ATLAS
#     ./sacred-test cli atlas validate data.json   # CLI command
#     ./sacred-test e2e biological_flow            # E2E test
#     ./sacred-test help                            # Show help

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FIELD_DIR="$SCRIPT_DIR"
PYTHON_ENV="python3"

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Sacred symbols
ATLAS="▲"
TATA="▼"
OBIWAN="●"
DOJO="◼︎"

print_banner() {
    echo -e "${PURPLE}"
    echo "    ╔═══════════════════════════════════════╗"
    echo "    ║     Sacred Parallel Testing System    ║"
    echo "    ║                                       ║"
    echo "    ║  ${ATLAS} ATLAS    ${TATA} TATA    ${OBIWAN} OBI-WAN   ${DOJO} DOJO  ║"
    echo "    ╚═══════════════════════════════════════╝"
    echo -e "${NC}"
}

print_help() {
    print_banner
    echo -e "${CYAN}Sacred Test Commands:${NC}"
    echo ""
    echo -e "${GREEN}System Management:${NC}"
    echo "  ./sacred-test status                    - Check system status"
    echo "  ./sacred-test sessions                  - List active sessions"
    echo "  ./sacred-test cleanup SESSION_ID       - Clean up session"
    echo ""
    echo -e "${GREEN}Testing Framework:${NC}"
    echo "  ./sacred-test test NODE SUITE          - Run test suite for node"
    echo "    Nodes: atlas, tata, obiwan, dojo"
    echo "    Suites: unit, integration, geometry, sovereign, e2e"
    echo ""
    echo -e "${GREEN}CLI Commands:${NC}"
    echo "  ./sacred-test cli NODE COMMAND [ARGS]  - Execute CLI command"
    echo "    Examples:"
    echo "      ./sacred-test cli atlas validate data.json"
    echo "      ./sacred-test cli tata log \"Test message\""
    echo "      ./sacred-test cli obiwan sync --dry-run"
    echo ""
    echo -e "${GREEN}End-to-End Testing:${NC}"
    echo "  ./sacred-test e2e SCENARIO             - Run E2E scenario"
    echo "    Scenarios: biological_flow, tetrahedral_navigation,"
    echo "               sacred_file_creation, symbolic_validation,"
    echo "               geometric_cleanliness, all"
    echo ""
    echo -e "${GREEN}Special Commands:${NC}"
    echo "  ./sacred-test all                      - Run all tests (comprehensive)"
    echo "  ./sacred-test quick NODE               - Quick test for specific node"
    echo "  ./sacred-test validate                 - Validate system integrity"
    echo ""
    echo -e "${YELLOW}Examples:${NC}"
    echo "  ./sacred-test test atlas unit"
    echo "  ./sacred-test cli dojo manifest --template test.md"
    echo "  ./sacred-test e2e biological_flow"
    echo "  ./sacred-test all"
}

check_dependencies() {
    if ! command -v python3 &> /dev/null; then
        echo -e "${RED}Error: python3 not found${NC}"
        exit 1
    fi
    
    if [ ! -f "$FIELD_DIR/testing/parallel_test_framework.py" ]; then
        echo -e "${RED}Error: Sacred testing system not found${NC}"
        exit 1
    fi
}

run_status() {
    echo -e "${BLUE}Checking Sacred System Status...${NC}"
    cd "$FIELD_DIR"
    $PYTHON_ENV testing/test_manager.py --status
}

run_sessions() {
    echo -e "${BLUE}Active Sessions:${NC}"
    cd "$FIELD_DIR"
    $PYTHON_ENV testing/test_manager.py --list-active
}

run_test() {
    local node=$1
    local suite=$2
    
    if [ -z "$node" ] || [ -z "$suite" ]; then
        echo -e "${RED}Usage: ./sacred-test test NODE SUITE${NC}"
        echo "Nodes: atlas, tata, obiwan, dojo"
        echo "Suites: unit, integration, geometry, sovereign, e2e"
        exit 1
    fi
    
    local symbol=""
    case $node in
        atlas) symbol="$ATLAS" ;;
        tata) symbol="$TATA" ;;
        obiwan) symbol="$OBIWAN" ;;
        dojo) symbol="$DOJO" ;;
    esac
    
    echo -e "${GREEN}Running ${suite} tests for ${symbol}${node^^}...${NC}"
    cd "$FIELD_DIR"
    $PYTHON_ENV testing/parallel_test_framework.py --node "$node" --suite "$suite" --isolated
}

run_cli() {
    local node=$1
    shift
    local command="$1"
    shift
    local args=("$@")
    
    if [ -z "$node" ] || [ -z "$command" ]; then
        echo -e "${RED}Usage: ./sacred-test cli NODE COMMAND [ARGS]${NC}"
        exit 1
    fi
    
    local symbol=""
    case $node in
        atlas) symbol="$ATLAS" ;;
        tata) symbol="$TATA" ;;
        obiwan) symbol="$OBIWAN" ;;
        dojo) symbol="$DOJO" ;;
    esac
    
    echo -e "${CYAN}Executing ${symbol}${node^^} CLI: $command${NC}"
    cd "$FIELD_DIR"
    $PYTHON_ENV cli/sacred_cli.py "$node" "$command" "${args[@]}" --isolated
}

run_e2e() {
    local scenario=$1
    
    if [ -z "$scenario" ]; then
        echo -e "${RED}Usage: ./sacred-test e2e SCENARIO${NC}"
        echo "Scenarios: biological_flow, tetrahedral_navigation, sacred_file_creation,"
        echo "           symbolic_validation, geometric_cleanliness, all"
        exit 1
    fi
    
    echo -e "${PURPLE}Running E2E scenario: $scenario${NC}"
    cd "$FIELD_DIR"
    
    if [ "$scenario" = "all" ]; then
        $PYTHON_ENV testing/e2e_test_system.py --run-all --safety-level isolated
    else
        $PYTHON_ENV testing/e2e_test_system.py --scenario "$scenario" --safety-level isolated
    fi
}

run_all() {
    echo -e "${PURPLE}Running comprehensive Sacred test suite...${NC}"
    echo ""
    
    echo -e "${YELLOW}Phase 1: System Status${NC}"
    run_status
    echo ""
    
    echo -e "${YELLOW}Phase 2: Unit Tests${NC}"
    for node in atlas tata obiwan dojo; do
        echo -e "${GREEN}Testing $node unit tests...${NC}"
        run_test "$node" "unit"
        echo ""
    done
    
    echo -e "${YELLOW}Phase 3: Integration Tests${NC}"
    run_test "atlas" "integration"
    echo ""
    
    echo -e "${YELLOW}Phase 4: Geometric Validation${NC}"
    run_test "atlas" "geometry"
    echo ""
    
    echo -e "${YELLOW}Phase 5: E2E Biological Flow${NC}"
    run_e2e "biological_flow"
    echo ""
    
    echo -e "${GREEN}✅ Comprehensive testing completed!${NC}"
}

run_quick() {
    local node=$1
    
    if [ -z "$node" ]; then
        echo -e "${RED}Usage: ./sacred-test quick NODE${NC}"
        exit 1
    fi
    
    local symbol=""
    case $node in
        atlas) symbol="$ATLAS" ;;
        tata) symbol="$TATA" ;;
        obiwan) symbol="$OBIWAN" ;;
        dojo) symbol="$DOJO" ;;
    esac
    
    echo -e "${YELLOW}Quick test for ${symbol}${node^^}...${NC}"
    run_test "$node" "unit"
    run_test "$node" "geometry"
}

validate_system() {
    echo -e "${BLUE}Validating Sacred System Integrity...${NC}"
    
    echo "🔍 Checking file structure..."
    required_files=(
        "testing/parallel_test_framework.py"
        "testing/e2e_test_system.py"
        "testing/test_manager.py"
        "cli/sacred_cli.py"
        "▲ATLAS/test_harness.py"
    )
    
    for file in "${required_files[@]}"; do
        if [ -f "$FIELD_DIR/$file" ]; then
            echo -e "  ✅ $file"
        else
            echo -e "  ❌ $file (missing)"
        fi
    done
    
    echo ""
    echo "🔍 Checking sacred nodes..."
    nodes=("▲ATLAS" "▼TATA" "●OBI-WAN" "◼︎DOJO")
    for node in "${nodes[@]}"; do
        if [ -d "$FIELD_DIR/$node" ]; then
            echo -e "  ✅ $node"
        else
            echo -e "  ❌ $node (missing)"
        fi
    done
    
    echo ""
    echo "🔍 Testing basic framework..."
    cd "$FIELD_DIR"
    if $PYTHON_ENV -c "import testing.parallel_test_framework; print('Framework import OK')" 2>/dev/null; then
        echo -e "  ✅ Framework import successful"
    else
        echo -e "  ❌ Framework import failed"
    fi
    
    echo ""
    echo -e "${GREEN}System validation completed${NC}"
}

cleanup_session() {
    local session_id=$1
    
    if [ -z "$session_id" ]; then
        echo -e "${RED}Usage: ./sacred-test cleanup SESSION_ID${NC}"
        exit 1
    fi
    
    echo -e "${YELLOW}Cleaning up session: $session_id${NC}"
    cd "$FIELD_DIR"
    $PYTHON_ENV testing/test_manager.py --cleanup "$session_id"
}

main() {
    check_dependencies
    
    case "$1" in
        "status")
            run_status
            ;;
        "sessions")
            run_sessions
            ;;
        "test")
            run_test "$2" "$3"
            ;;
        "cli")
            shift
            run_cli "$@"
            ;;
        "e2e")
            run_e2e "$2"
            ;;
        "all")
            run_all
            ;;
        "quick")
            run_quick "$2"
            ;;
        "validate")
            validate_system
            ;;
        "cleanup")
            cleanup_session "$2"
            ;;
        "help"|"-h"|"--help"|"")
            print_help
            ;;
        *)
            echo -e "${RED}Unknown command: $1${NC}"
            echo "Use './sacred-test help' for usage information"
            exit 1
            ;;
    esac
}

main "$@"
